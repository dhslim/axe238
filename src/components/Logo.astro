---
interface Props {
  wordmark?: boolean;
  class?: string;
}
const { wordmark = true, class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<a class:list={['logo', className]} href={base} aria-label="Church of Philadelphia — home">
  <svg class="logo__mark" viewBox="0 0 130 108" fill="none" stroke="currentColor" aria-hidden="true">
    <path d="M20 46 L65 8 L110 46" stroke-width="6.5" stroke-linecap="round" stroke-linejoin="round" />
    <g fill="currentColor" stroke="none">
      <rect x="58" y="27" width="6.5" height="6.5" />
      <rect x="64.5" y="27" width="6.5" height="6.5" />
      <rect x="58" y="35" width="6.5" height="6.5" />
      <rect x="64.5" y="35" width="6.5" height="6.5" />
    </g>
    <g transform="translate(11.7,32.5) scale(0.86)">
      <circle cx="26" cy="60" r="16" stroke-width="8.5" />
      <rect x="40" y="54" width="78" height="12" rx="3" fill="currentColor" stroke="none" />
      <g fill="currentColor" stroke="none">
        <rect x="66" y="40" width="8" height="14" />
        <rect x="77" y="31" width="7" height="23" />
        <rect x="87" y="44" width="6" height="10" />
        <rect x="96" y="25" width="8" height="29" />
        <rect x="108" y="37" width="6" height="17" />
      </g>
    </g>
  </svg>
  {wordmark && <span class="logo__wm">Philadelphia</span>}
</a>
<style>
  .logo { display: inline-flex; align-items: center; gap: 0.55rem; text-decoration: none; color: var(--color-gold-deep); }
  .logo__mark { width: 38px; height: auto; flex: 0 0 auto; }
  .logo__wm { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--color-ink); letter-spacing: 0.01em; }
</style>
